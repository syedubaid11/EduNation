# ═══════════════════════════════════════════════════════════════
# EduNation — Root .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Dependencies ──
node_modules/

# ── Environment Variables (NEVER commit secrets) ──
.env
.env.local
.env.*.local

# ── Build Outputs ──
dist/
dist-ssr/
build/
.next/
out/
*.tsbuildinfo

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS Files ──
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor / IDE ──
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Deployment / Hosting ──
.vercel/
.turbo/

# ── Expo / React Native ──
.expo/
.expo-shared/

# ── Database / Local Files ──
*.db
*.sqlite
*.sqlite3
prisma/migrations/

# ── Uploads ──
uploads/
public/uploads/

# ── Security / Certificates ──
*.pem
*.key
*.crt
serviceAccountKey.json
firebase-adminsdk.json

# ── Testing ──
coverage/
.nyc_output/
jest-cache/
playwright-report/
test-results/

# ── Misc ──
*.local
*.tgz
.cache/

# ── Personal / Local Docs ──

tmp/
temp/